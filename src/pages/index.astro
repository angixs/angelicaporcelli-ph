---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getGallery } from '../lib/collections';

const collections = (await getCollection('collections'))
	.filter((collection) => collection.data.featured)
	.map((collection) => ({
		collection,
		gallery: getGallery(collection),
	}))
	.sort((a, b) => b.collection.data.year.localeCompare(a.collection.data.year));
---

<Layout title="Angelica Porcelli | Photography Portfolio">
	<header class="topbar">
		<div class="site-shell topbar__inner">
			<a class="brand" href="/" aria-label="Angelica Porcelli Photography home">
				<span class="brand__name">Angelica Porcelli</span>
				<span class="brand__meta">Photography</span>
			</a>
			<nav class="nav" aria-label="Portfolio sections">
				<a href="#resume">CV</a>
				<a href="#studies">Studies</a>
				<a href="#portfolio">Portfolio</a>
				<a href="#contact">Contact</a>
			</nav>
		</div>
	</header>

	<main>
		<section class="site-shell hero" id="resume">
			<div class="hero__copy">
				<p class="eyebrow">Photographer / nature, animals, portrait, street, events</p>
				<h1>Angelica Porcelli</h1>
				<p class="hero__lede">
					I am a photographer passionate about visual storytelling. I take photos to express my point of view and interpret reality through my own eyes, striving to capture the world as I see it. 
                    I especially love capturing nature and its beauty, as well as portraits, seeking out what makes every face and every landscape unique.
				</p>
				<div class="hero__actions" aria-label="Portfolio actions">
					<a class="button button--primary" href="#portfolio">View photos</a>
					<a class="button button--ghost" href="#contact">Contact</a>
				</div>
			</div>

			<aside class="resume-panel" aria-label="Short CV">
				<img
					class="resume-panel__image"
					src="/photos/me.jpeg"
					alt="Portrait of Angelica Porcelli."
					loading="eager"
				/>
			</aside>
		</section>

		<section class="site-shell section studies-section" id="studies">
			<div class="studies-section__intro">
				<p class="eyebrow">Study career</p>
				<h2>Creative work shaped by digital communication and computer science.</h2>
			</div>
			<div class="study-list" aria-label="Study career">
				<article class="study-item">
					<span>01</span>
					<div>
						<h3>Bachelor degree</h3>
						<p>Computer Science for Digital Communication, studied in Milan.</p>
					</div>
				</article>
				<article class="study-item">
					<span>02</span>
					<div>
						<h3>Master degree</h3>
						<p>Computer Science, continuing the academic path in Milan.</p>
					</div>
				</article>
				<article class="study-item">
					<span>03</span>
					<div>
						<h3>Photography courses</h3>
						<p>Previous photography courses focused on image-making, composition, and visual practice.</p>
					</div>
				</article>
			</div>
		</section>

		<section class="section category-section section--dark" id="portfolio">
			<div class="site-shell">
				<div class="section__head">
					<div>
						<p class="eyebrow">Portfolio section</p>
						<h2>Portfolio</h2>
					</div>
					<p>Selected photography collections across nature, animals, portrait, street, and events work.</p>
				</div>

				<div class="collection-grid">
					{collections.length > 0 ? (
						collections.map(({ collection, gallery }) => {
							if (!gallery.cover) {
								return (
									<a class="collection-card collection-card--empty" href={`/collections/${collection.id}/`}>
										<div class="collection-card__body">
											<h3>{collection.data.title}</h3>
											<p>{collection.data.subtitle}</p>
											<div class="collection-card__footer">
												<span>0 photos</span>
												<span>Open gallery</span>
											</div>
										</div>
									</a>
								);
							}

							return (
								<a class="collection-card" href={`/collections/${collection.id}/`}>
									<img src={gallery.cover.src} alt={gallery.cover.alt} loading="lazy" />
									<div class="collection-card__body">
										<h3>{collection.data.title}</h3>
									<p>{collection.data.subtitle}</p>
										<div class="collection-card__footer">
											<span>{gallery.images.length} photos</span>
											<span>Open gallery</span>
										</div>
									</div>
								</a>
							);
						})
					) : (
						<div class="empty-state">
							<p>Add a collection JSON file, then drop photos into its matching folder.</p>
						</div>
					)}
				</div>
			</div>
		</section>

		<section class="site-shell section contact-section" id="contact">
			<div>
				<p class="eyebrow">Contact</p>
				<h2>My Contact</h2>
			</div>
			<div class="contact-links" aria-label="Contact links">
				<a class="contact-link contact-link--gmail" href="mailto:angelicaporcelli.photo@gmail.com">
					<span class="contact-link__icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" role="img">
							<path d="M3.75 6.25h2.7L12 10.45l5.55-4.2h2.7v11.5h-3.05v-6.2L12 15.35l-5.2-3.8v6.2H3.75V6.25Z" />
						</svg>
					</span>
					<span class="contact-link__text">
						<span>Gmail</span>
						<small>angelicaporcelli.photo@gmail.com</small>
					</span>
				</a>
				<a
					class="contact-link contact-link--instagram"
					href="https://www.instagram.com/angixs.photography/"
				>
					<span class="contact-link__icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" role="img">
							<path
								fill-rule="evenodd"
								clip-rule="evenodd"
								d="M8.25 3.75h7.5a4.5 4.5 0 0 1 4.5 4.5v7.5a4.5 4.5 0 0 1-4.5 4.5h-7.5a4.5 4.5 0 0 1-4.5-4.5v-7.5a4.5 4.5 0 0 1 4.5-4.5Zm0 2.2a2.3 2.3 0 0 0-2.3 2.3v7.5a2.3 2.3 0 0 0 2.3 2.3h7.5a2.3 2.3 0 0 0 2.3-2.3v-7.5a2.3 2.3 0 0 0-2.3-2.3h-7.5Zm3.75 2.8a3.25 3.25 0 1 1 0 6.5 3.25 3.25 0 0 1 0-6.5Zm0 2.05a1.2 1.2 0 1 0 0 2.4 1.2 1.2 0 0 0 0-2.4Zm4.1-2.3a1.05 1.05 0 1 0 0-2.1 1.05 1.05 0 0 0 0 2.1Z"
							/>
						</svg>
					</span>
					<span class="contact-link__text">
						<span>Instagram</span>
						<small>@angixs.photography</small>
					</span>
				</a>
				<a
					class="contact-link contact-link--linkedin"
					href="https://www.linkedin.com/in/angelica-porcelli-16ba84275/"
				>
					<span class="contact-link__icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" role="img">
							<path d="M5 8.75h3v10h-3v-10Zm1.5-4.8a1.75 1.75 0 1 1 0 3.5 1.75 1.75 0 0 1 0-3.5Zm4.35 4.8h2.85v1.35c.55-.9 1.55-1.6 3.05-1.6 2.55 0 4.25 1.65 4.25 5.15v5.1h-3v-4.8c0-1.7-.62-2.65-1.95-2.65-1.45 0-2.2 1.05-2.2 2.65v4.8h-3v-10Z" />
						</svg>
					</span>
					<span class="contact-link__text">
						<span>LinkedIn</span>
						<small>/in/angelicaporcelli</small>
					</span>
				</a>
			</div>
		</section>
	</main>

	<footer class="footer">
		<div class="site-shell footer__inner">
			<span>Angelica Porcelli Photography</span>
			<a class="pill-link" href="#contact">Contact</a>
		</div>
	</footer>
</Layout>
